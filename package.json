{
	"name": "eslint-config-expo-magic-monorepo",
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	},
	"packageManager": "bun@1.3.11",
	"private": true,
	"scripts": {
		"test": "bun test packages/eslint-config-expo-magic/index.test.ts",
		"check-pm": "node packages/eslint-config-expo-magic/check-pm.js",
		"ci": "bun install --frozen-lockfile",
		"validate": "cd test-project && bun run validate",
		"smoke:pack": "bun scripts/smoke-packed-consumer.js",
		"smoke:preview": "bun scripts/smoke-packed-consumer.js --preview",
		"smoke:release": "bun scripts/smoke-packed-consumer.js --all-lanes",
		"report:config": "node scripts/generate-config-report.js",
		"report:release-notes": "node scripts/generate-release-notes.js",
		"release:check": "node scripts/release-check.js",
		"cleanup:npm": "rimraf node_modules packages/**/node_modules test-project/node_modules",
		"publish-package": "bun scripts/publish-package.js"
	},
	"workspaces": [
		"packages/eslint-config-expo-magic",
		"test-project"
	],
	"devDependencies": {
		"@types/react": "~19.2.17",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"bun-types": "latest",
		"eslint": "^10.1.0",
		"eslint-config-expo": "^56.0.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jest": "^29.15.1",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-19-upgrade": "^1.7.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-native": "^5.0.0",
		"eslint-plugin-testing-library": "^7.16.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"jest": "^30.3.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.0"
	},
	"overrides": {
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@typescript-eslint/utils": "^8.58.0"
	}
}
