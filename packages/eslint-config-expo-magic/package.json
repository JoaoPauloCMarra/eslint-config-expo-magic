{
	"name": "eslint-config-expo-magic",
	"version": "2.7.0",
	"description": "ESLint flat config for Expo, React Native, and TypeScript projects",
	"keywords": [
		"eslint",
		"eslint-flat-config",
		"eslintconfig",
		"eslint-config",
		"eslint-plugin",
		"react",
		"react-native",
		"expo",
		"eslint-expo",
		"expo-eslint",
		"react-native-eslint",
		"typescript",
		"prettier",
		"jest",
		"testing-library",
		"mobile",
		"linting"
	],
	"homepage": "https://github.com/JoaoPauloCMarra/eslint-config-expo-magic#readme",
	"bugs": {
		"url": "https://github.com/JoaoPauloCMarra/eslint-config-expo-magic/issues"
	},
	"license": "MIT",
	"author": {
		"name": "João Paulo Costa Marra",
		"email": "joaopaulocmarra@gmail.com",
		"url": "https://github.com/JoaoPauloCMarra/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoaoPauloCMarra/eslint-config-expo-magic.git"
	},
	"main": "index.js",
	"module": "index.mjs",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./index.js",
			"import": "./index.mjs"
		},
		"./base": {
			"types": "./base.d.ts",
			"require": "./base.js",
			"import": "./base.mjs"
		},
		"./strict": {
			"types": "./strict.d.ts",
			"require": "./strict.js",
			"import": "./strict.mjs"
		},
		"./no-prettier": {
			"types": "./no-prettier.d.ts",
			"require": "./no-prettier.js",
			"import": "./no-prettier.mjs"
		},
		"./typed": {
			"types": "./typed.d.ts",
			"require": "./typed.js",
			"import": "./typed.mjs"
		},
		"./app-guardrails": {
			"types": "./app-guardrails.d.ts",
			"require": "./app-guardrails.js",
			"import": "./app-guardrails.mjs"
		},
		"./component-structure": {
			"types": "./component-structure.d.ts",
			"require": "./component-structure.js",
			"import": "./component-structure.mjs"
		},
		"./deprecated-apis": {
			"types": "./deprecated-apis.d.ts",
			"require": "./deprecated-apis.js",
			"import": "./deprecated-apis.mjs"
		},
		"./feature-boundaries": {
			"types": "./feature-boundaries.d.ts",
			"require": "./feature-boundaries.js",
			"import": "./feature-boundaries.mjs"
		},
		"./native-ui": {
			"types": "./native-ui.d.ts",
			"require": "./native-ui.js",
			"import": "./native-ui.mjs"
		},
		"./pr-guardrails": {
			"types": "./pr-guardrails.d.ts",
			"require": "./pr-guardrails.js",
			"import": "./pr-guardrails.mjs"
		},
		"./react-compiler": {
			"types": "./react-compiler.d.ts",
			"require": "./react-compiler.js",
			"import": "./react-compiler.mjs"
		},
		"./reanimated": {
			"types": "./reanimated.d.ts",
			"require": "./reanimated.js",
			"import": "./reanimated.mjs"
		},
		"./semantic-colors": {
			"types": "./semantic-colors.d.ts",
			"require": "./semantic-colors.js",
			"import": "./semantic-colors.mjs"
		},
		"./storybook": {
			"types": "./storybook.d.ts",
			"require": "./storybook.js",
			"import": "./storybook.mjs"
		},
		"./worklets": {
			"types": "./worklets.d.ts",
			"require": "./worklets.js",
			"import": "./worklets.mjs"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"expo-magic-pr-guardrails": "bin/pr-guardrails.js"
	},
	"sideEffects": false,
	"files": [
		"index.js",
		"index.mjs",
		"base.js",
		"base.mjs",
		"strict.js",
		"strict.mjs",
		"no-prettier.js",
		"no-prettier.mjs",
		"typed.js",
		"typed.mjs",
		"app-guardrails.js",
		"app-guardrails.mjs",
		"component-structure.js",
		"component-structure.mjs",
		"deprecated-apis.js",
		"deprecated-apis.mjs",
		"feature-boundaries.js",
		"feature-boundaries.mjs",
		"native-ui.js",
		"native-ui.mjs",
		"pr-guardrails.js",
		"pr-guardrails.mjs",
		"react-compiler.js",
		"react-compiler.mjs",
		"reanimated.js",
		"reanimated.mjs",
		"semantic-colors.js",
		"semantic-colors.mjs",
		"storybook.js",
		"storybook.mjs",
		"worklets.js",
		"worklets.mjs",
		"index.d.ts",
		"base.d.ts",
		"strict.d.ts",
		"no-prettier.d.ts",
		"typed.d.ts",
		"app-guardrails.d.ts",
		"component-structure.d.ts",
		"deprecated-apis.d.ts",
		"feature-boundaries.d.ts",
		"native-ui.d.ts",
		"pr-guardrails.d.ts",
		"react-compiler.d.ts",
		"reanimated.d.ts",
		"semantic-colors.d.ts",
		"storybook.d.ts",
		"worklets.d.ts",
		"README.md",
		"bin/*.js",
		"utils/**/*.js",
		".prettierrc.js"
	],
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc -p tsconfig.types.json",
		"prepublishOnly": "node ../../scripts/release-check.js",
		"check-pm": "node check-pm.js",
		"pack:dry-run": "bun pm pack --dry-run",
		"publish:dry-run": "bun publish --dry-run",
		"ci": "bun install --frozen-lockfile",
		"dev": "bun run --if-present",
		"build": "bun run --if-present"
	},
	"dependencies": {
		"@eslint/compat": "^2.0.3",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@typescript-eslint/utils": "^8.58.0",
		"eslint": "^10.1.0",
		"eslint-config-expo": "^56.0.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jest": "^29.15.1",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-19-upgrade": "^1.7.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-native": "^5.0.0",
		"eslint-plugin-testing-library": "^7.16.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"prettier": "^3.8.1",
		"typescript-eslint": "^8.58.0"
	},
	"peerDependencies": {
		"expo": "^54.0.33 || ^55.0.0 || ^56.0.0",
		"react": "^19.1.0 || ^19.2.0",
		"react-test-renderer": "^19.1.0 || ^19.2.0",
		"typescript": ">=5.9.3 <7.0.0"
	},
	"installPeers": false,
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	},
	"packageManager": "bun@1.3.11",
	"devDependencies": {
		"@babel/preset-env": "^7.29.2",
		"babel-jest": "^30.3.0",
		"bun-types": "latest",
		"jest": "^30.3.0"
	}
}
